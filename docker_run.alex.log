  docker run \
    --name dimos_simulation_container \
    --rm \
    --shm-size=8g \
    -it \
    --network host \
    --cap-add NET_ADMIN \
    --runtime runc \
    -e DISPLAY=:1 \
    -e QT_X11_NO_MITSHM=1 \
    -e NVIDIA_VISIBLE_DEVICES=all \
    -e NVIDIA_DRIVER_CAPABILITIES=all \
    -e ROS_DOMAIN_ID=42 \
    -e ROBOT_CONFIG_PATH=mechanum_drive \
    -e ROBOT_IP= \
    -e MODE=simulation \
    -e USE_ROUTE_PLANNER=false \
    -e USE_RVIZ=false \
    -e HARDWARE_MODE=false \
    -e RMW_IMPLEMENTATION=rmw_fastrtps_cpp \
    -e FASTRTPS_DEFAULT_PROFILES_FILE=/ros2_ws/config/fastdds.xml \
    -e LOCALIZATION_METHOD=arise_slam \
    -e \
    XAUTHORITY=/tmp/.Xauthority \
    -v \
    /tmp/.X11-unix:/tmp/.X11-unix:rw \
    -v \
    /home/dimos/dimos/docker/navigation/unity_models:/ros2_ws/src/ros-navigation-autonomy-stack/src/base_autonomy/vehicle_simulator/mesh/unity:rw \
    -v \
    /home/dimos/dimos/docker/navigation/unity_models:/ros2_ws/src/base_autonomy/vehicle_simulator/mesh/unity:rw \
    -v \
    /home/dimos/dimos/docker/navigation/unity_models:/ros2_ws/src/ros-navigation-autonomy-stack/src/base_autonomy/vehicle_simulator/mesh/real_world:rw \
    -v \
    /home/dimos/dimos/docker/navigation/unity_models:/ros2_ws/src/base_autonomy/vehicle_simulator/mesh/real_world:rw \
    -v \
    /home/dimos/dimos/docker/navigation/../..:/workspace/dimos:rw \
    -v \
    /home/dimos/dimos/docker/navigation/bagfiles:/ros2_ws/bagfiles:rw \
    -v \
    /home/dimos/dimos/docker/navigation/config:/ros2_ws/config:rw \
    -v \
    /home/dimos/dimos/docker/navigation/../../dimos/navigation/dimos_module_entrypoint.sh:/usr/local/bin/dimos_module_entrypoint.sh:ro \
    -v \
    /home/dimos/dimos/docker/navigation/ros-navigation-autonomy-stack/src/utilities/ROS-TCP-Endpoint/ros_tcp_endpoint/server.py:/ros2_ws/install/ros_tcp_endpoint/lib/python3.10/site-packages/ros_tcp_endpoint/server.py:ro \
    -v \
    /run/user/1000/gdm/Xauthority:/tmp/.Xauthority:ro \
    --device \
    /dev/dri:/dev/dri \
    --device /dev/input:/dev/input \
    -w /workspace/dimos \
    dimos_autonomy_stack:humble \
    /usr/local/bin/dimos_module_entrypoint.sh